{
  "setup-worktree": [
    "cp $ROOT_WORKTREE_PATH/.env.local .env.local",
    "cp $ROOT_WORKTREE_PATH/frontend/.env.local frontend/.env.local",
    "pnpm install",
    "cd frontend && pnpm install",
    "cd backend/renderer_service && uv sync",
    "cd backend/image_processing_service && pnpm install"
  ]
}
